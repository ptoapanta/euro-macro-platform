# Copiar este archivo como ".env" y ajustar valores según tu entorno.
# NUNCA subir el archivo ".env" real al repositorio (ya está en .gitignore).

# Base de datos (por defecto SQLite local, no requiere configuración)
DATABASE_URL=sqlite:///data_layer/storage/euro_macro.db

# Seguridad de la API (header X-API-Key)
API_KEY=euro_macro_key_2024

# Fuente de datos EUR/USD
USE_REAL_EURUSD=true
EURUSD_TICKER=EURUSD=X
EURUSD_HISTORY_PERIOD=6mo

# Umbral de alertas automáticas (% de variación)
ALERT_THRESHOLD_PCT=1.0

# Webhook saliente hacia Make/Zapier (se configura en Etapa 6)
OUTBOUND_WEBHOOK_URL=

# Entorno
DEBUG=true
API_PORT=5000
STREAMLIT_PORT=8501
